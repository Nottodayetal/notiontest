{
  "name": "flowcast",
  "version": "0.1.0",
  "description": "Windows desktop app for streaming Yandex Music into the FlowCast virtual microphone.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/electron-vite.mjs dev",
    "build": "npm run typecheck && node scripts/electron-vite.mjs build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "preview": "node scripts/electron-vite.mjs preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ya-music-api-ts-lib": "^1.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "app.flowcast.desktop",
    "productName": "FlowCast",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
